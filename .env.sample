# -----------------------------------------------------
# Configuración Vertex AI (Para usar el Oráculo Gemma 4)
# -----------------------------------------------------

# ID del proyecto en Google Cloud
VERTEX_PROJECT_ID=tu_proyecto_id_aqui

# Región donde desplegaste el modelo
VERTEX_REGION=us-central1

# Opcionalmente, puedes sobrescribir el endpoint o nombre base
GEMMA_BASE_MODEL=gemma-4-26b-a4b-it
GEMMA_EDGE_MODEL=google/gemma-2b-it
